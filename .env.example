# Bankr API key — get yours at bankr.bot/api
# Enable both "Agent API" and "Wallet API" feature flags on the key.
# Partnership keys use bk_ptr_ prefix and unlock sub-account provisioning.
BANKR_API_KEY=bk_your_api_key_here

# Set to "true" to show the LIVE badge in the UI (cosmetic only)
NEXT_PUBLIC_BANKR_LIVE=false
